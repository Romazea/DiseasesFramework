<?xml version="1.0" encoding="utf-8" ?>
<Patch>
    <!-- Apparel patch -->
    <!-- Injects fomite logic into all apparel inheriting from ApparelBase -->
    <Operation Class="PatchOperationSequence">
        <operations>
            <li Class="PatchOperationConditional">
                <xpath>/Defs/ThingDef[@Name="ApparelBase"]/comps</xpath>
                <nomatch Class="PatchOperationAdd">
                    <xpath>/Defs/ThingDef[@Name="ApparelBase"]</xpath>
                    <value>
                        <comps />
                    </value>
                </nomatch>
            </li>

            <!-- Adds the fomite component with a 2-day pathogen decay period for apparel -->
            <li Class="PatchOperationAdd">
                <xpath>/Defs/ThingDef[@Name="ApparelBase"]/comps</xpath>
                <value>
                    <li Class="DiseasesFramework.InfectionVectors.DF_Fomites.CompProperties_Fomite">
                        <daysToDecay>2.0</daysToDecay>
                    </li>
                </value>
            </li>
        </operations>
    </Operation>

    <!-- Beds patch -->
    <!-- Injects fomite logic into all objects functioning as beds -->
    <Operation Class="PatchOperationSequence">
        <operations>
            <li Class="PatchOperationConditional">
                <xpath>//ThingDef[thingClass="Building_Bed"]/comps</xpath>
                <nomatch Class="PatchOperationAdd">
                    <xpath>//ThingDef[thingClass="Building_Bed"]</xpath>
                    <value>
                        <comps />
                    </value>
                </nomatch>
            </li>

            <!-- Adds the fomite component with a 3-day pathogen decay period for beds -->
            <li Class="PatchOperationAdd">
                <xpath>//ThingDef[thingClass="Building_Bed"]/comps</xpath>
                <value>
                    <li Class="DiseasesFramework.InfectionVectors.DF_Fomites.CompProperties_Fomite">
                        <daysToDecay>3.0</daysToDecay>
                    </li>
                </value>
            </li>
        </operations>
    </Operation>

</Patch>