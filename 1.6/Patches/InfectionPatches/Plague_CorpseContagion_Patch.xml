<?xml version="1.0" encoding="utf-8" ?>
<Patch>
    <Operation Class="PatchOperationSequence">
        <operations>

            <li Class="PatchOperationConditional">
                <xpath>/Defs/HediffDef[defName="Plague"]/comps</xpath>
                <nomatch Class="PatchOperationAdd">
                    <xpath>/Defs/HediffDef[defName="Plague"]</xpath>
                    <value>
                        <comps />
                    </value>
                </nomatch>
            </li>

            <li Class="PatchOperationAdd">
                <xpath>/Defs/HediffDef[defName="Plague"]/comps</xpath>
                <value>
                    <li Class="DiseasesFramework.InfectionVectors.HediffCompProperties_CorpseContagion">
                        <radius>5.0</radius>
                        <infectionChance>1.0</infectionChance>
                        <requireLineOfSight>true</requireLineOfSight>
                        <sendNotification>true</sendNotification>
                        <useLetterInsteadOfMessage>true</useLetterInsteadOfMessage>
                    </li>
                </value>
            </li>

        </operations>
    </Operation>
</Patch>