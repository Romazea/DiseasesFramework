<?xml version="1.0" encoding="utf-8" ?>
<Patch>
    <Operation Class="PatchOperationSequence">
        <operations>
            <li Class="PatchOperationConditional">
                <xpath>/Defs/ThingDef[@Name="ApparelBase"]/comps</xpath>
                <nomatch Class="PatchOperationAdd">
                    <xpath>/Defs/ThingDef[@Name="ApparelBase"]</xpath>
                    <value>
                        <comps />
                    </value>
                </nomatch>
            </li>
            <li Class="PatchOperationAdd">
                <xpath>/Defs/ThingDef[@Name="ApparelBase"]/comps</xpath>
                <value>
                    <li Class="DiseasesFramework.InfectionVectors.CompProperties_Fomite">
                        <daysToDecay>2.0</daysToDecay>
                    </li>
                </value>
            </li>
        </operations>
    </Operation>

    <Operation Class="PatchOperationSequence">
        <operations>
            <li Class="PatchOperationConditional">
                <xpath>//ThingDef[thingClass="Building_Bed"]/comps</xpath>
                <nomatch Class="PatchOperationAdd">
                    <xpath>//ThingDef[thingClass="Building_Bed"]</xpath>
                    <value>
                        <comps />
                    </value>
                </nomatch>
            </li>
            <li Class="PatchOperationAdd">
                <xpath>//ThingDef[thingClass="Building_Bed"]/comps</xpath>
                <value>
                    <li Class="DiseasesFramework.InfectionVectors.CompProperties_Fomite">
                        <daysToDecay>3.0</daysToDecay>
                    </li>
                </value>
            </li>
        </operations>
    </Operation>

    <Operation Class="PatchOperationSequence">
        <operations>
            <li Class="PatchOperationConditional">
                <xpath>/Defs/HediffDef[defName="Flu"]/comps</xpath>
                <nomatch Class="PatchOperationAdd">
                    <xpath>/Defs/HediffDef[defName="Flu"]</xpath>
                    <value>
                        <comps />
                    </value>
                </nomatch>
            </li>
            <li Class="PatchOperationAdd">
                <xpath>/Defs/HediffDef[defName="Flu"]/comps</xpath>
                <li>
                    <li Class="DiseasesFramework.InfectionVectors.HediffCompProperties_FomiteContagion">
                        <contaminateInterval>2500</contaminateInterval>
                        <sendNotification>true</sendNotification>
                        <useLetterInsteadOfMessage>false</useLetterInsteadOfMessage>
                    </li>
                </li>
            </value>
        </li>
    </operations>
</Operation>
</Patch>