<?xml version="1.0" encoding="utf-8" ?>
<Patch>

    <Operation Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[@ParentName="BodyPartProstheticImperialBase" or @ParentName="BodyPartBionicImperialBase" or @ParentName="BodyPartRoyalBase" or @ParentName="BodyPartNaturalBase"]</xpath>
        <value>
            <comps>
                <li Class="DiseasesFramework.InfectionVectors.CompProperties_ContaminatedBodyPart"/>
            </comps>
        </value>
    </Operation>

    <Operation Class="PatchOperationAdd">
        <xpath>Defs/HediffDef[defName="Flu"]</xpath>
        <value>
            <comps>
                <li Class="DiseasesFramework.InfectionVectors.HediffCompProperties_OrganContagion">
                    <infectionChance>1.0</infectionChance>
                    <sendNotification>true</sendNotification>
                    <useLetterInsteadOfMessage>false</useLetterInsteadOfMessage>
                    <canInfectArtificialPart>true</canInfectArtificialPart>
                </li>
            </comps>
        </value>
    </Operation>

</Patch>